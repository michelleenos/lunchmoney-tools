{
    "include": ["src/**/*.ts"],
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",

        "target": "ES2020",
        "noImplicitAny": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rewriteRelativeImportExtensions": true,

        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,

        "declaration": true,
        "types": ["node"]
    }
}
